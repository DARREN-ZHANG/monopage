{
  "name": "@monopage/web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local": "vite --mode development",
    "dev:remote": "VITE_API_TARGET=https://your-api.example.com vite --mode development",
